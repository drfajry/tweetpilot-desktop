{
  "name": "nashir",
  "version": "1.1.0",
  "description": "ناشر - النشر الذكي على منصات التواصل",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "dependencies": {
    "twitter-api-v2": "^1.17.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.nashir.app",
    "productName": "nashir",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.bin/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "renderer/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerLanguages": ["en_US"]
    }
  }
}
