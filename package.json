{
  "name": "nashir",
  "version": "1.0.0",
  "description": "ناشر - النشر الذكي على منصات التواصل",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "dependencies": {
    "twitter-api-v2": "^1.17.0",
    "better-sqlite3": "^9.4.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.nashir.app",
    "productName": "ناشر",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "renderer/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "protocols": {
      "name": "nashir",
      "schemes": ["nashir"]
    }
  }
}
