{
  "name": "nashir",
  "version": "1.1.0",
  "description": "ناشر - النشر الذكي على منصات التواصل",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build-win": "electron-builder --win --x64"
  },
  "dependencies": {
    "twitter-api-v2": "^1.17.0",
    "better-sqlite3": "^9.4.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.nashir.desktop.v2",
    "productName": "ناشر",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "renderer/icon.ico"
    },
    "portable": {
      "artifactName": "Nashir-Portable.exe"
    },
    "protocols": {
      "name": "nashir",
      "schemes": ["nashir"]
    },
    "extraResources": [],
    "asar": true
  }
}
